# Byte-compiled / cache
__pycache__/
*.py[cod]
*$py.class

# Packaging
*.egg
*.egg-info/
build/
dist/
.eggs/

# Virtual environments
.venv/
venv/
env/
ENV/

# Tooling caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
.tox/

# Editors / OS
.vscode/
.idea/
*.swp
.DS_Store
Thumbs.db

# Local-only
*.log
*.bak
*.tmp
*.local
.nexus-mcp.json

# Depth-eval auto-generated artifacts. Hand-written research writeups
# (e.g. 2026-04-29-bundle4-evaluation.md) are committed by adding them
# explicitly with `git add -f`. The README and the auto-rendered .md/json
# pairs are not tracked — research docs link out and document repro.
docs/research/depth/*.json
!docs/research/depth/README.md
